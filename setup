#!/bin/zsh
set -euo pipefail

gateway_root="${0:A:h}"
: "${GATEWAY_TELEGRAM_TOKEN:?GATEWAY_TELEGRAM_TOKEN is required}"
: "${GATEWAY_TELEGRAM_CHAT_ID:?GATEWAY_TELEGRAM_CHAT_ID is required}"
: "${HOME:?HOME is required}"
: "${PATH:?PATH is required}"

gateway_required_commands=(
  awk
  cargo
  codex
  date
  fastfetch
  fzf
  gh
  git
  go
  id
  jq
  launchctl
  mkdir
  mv
  node
  parallel
  rg
  rm
  rustc
  sed
  sleep
  xargs
)
gateway_missing_commands=()

for name in "${gateway_required_commands[@]}"; do
  if ! command -v "$name" >/dev/null 2>&1; then
    gateway_missing_commands+=("$name")
  fi
done

if (( ${#gateway_missing_commands[@]} )); then
  print -u2 "setup cannot register ai.gateway because required commands are missing from PATH."
  print -u2 "Install these commands or fix PATH before running setup:"
  for name in "${gateway_missing_commands[@]}"; do
    print -u2 "  - $name"
  done
  exit 69
fi

gateway_label="ai.gateway"
gateway_domain="gui/$(id -u)"
gateway_launch="$gateway_root/launch"
gateway_plist_template="$gateway_root/$gateway_label.plist"
gateway_plist_dest="$HOME/Library/LaunchAgents/$gateway_label.plist"
gateway_plist_tmp=
trap '[[ -z "${gateway_plist_tmp:-}" ]] || rm -f "$gateway_plist_tmp"' EXIT

if [[ ! -x "$gateway_launch" ]]; then
  print -u2 "LaunchAgent launcher is missing or not executable: $gateway_launch"
  exit 66
fi

if [[ ! -f "$gateway_plist_template" ]]; then
  print -u2 "LaunchAgent plist template is missing: $gateway_plist_template"
  exit 66
fi

cd "$gateway_root"
cargo build --release

gateway_xml_escape() {
  jq -nr --arg value "$1" '$value | @html'
}

gateway_launch_xml="$(gateway_xml_escape "$gateway_launch")"
gateway_plist_tmp="$gateway_plist_dest.$$"

mkdir -p "${gateway_plist_dest:h}"
while IFS= read -r line || [[ -n "$line" ]]; do
  line="${line//__GATEWAY_LAUNCH__/$gateway_launch_xml}"
  print -r -- "$line"
done < "$gateway_plist_template" > "$gateway_plist_tmp"
mv -f "$gateway_plist_tmp" "$gateway_plist_dest"
gateway_plist_tmp=

launchctl bootout "$gateway_domain/$gateway_label" 2>/dev/null || true
sleep 1
launchctl bootstrap "$gateway_domain" "$gateway_plist_dest"
sleep 1
launchctl kickstart -k "$gateway_domain/$gateway_label"

print -- "registered and started $gateway_label from $gateway_plist_dest"
