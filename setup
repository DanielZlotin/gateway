#!/bin/zsh
set -euo pipefail

gateway_root="${0:A:h}"
: "${GATEWAY_TELEGRAM_TOKEN:?GATEWAY_TELEGRAM_TOKEN is required}"
: "${GATEWAY_TELEGRAM_CHAT_ID:?GATEWAY_TELEGRAM_CHAT_ID is required}"
: "${HOME:?HOME is required}"
: "${PATH:?PATH is required}"

gateway_required_commands=(
  awk
  cargo
  codex
  date
  fastfetch
  ffmpeg
  fzf
  gh
  git
  go
  id
  jq
  launchctl
  mkdir
  mv
  node
  parallel
  rg
  rm
  rustc
  sed
  sleep
  whisper
  xargs
)
gateway_missing_commands=()

gateway_collect_missing_commands() {
  gateway_missing_commands=()
  local gateway_name
  for gateway_name in "${gateway_required_commands[@]}"; do
    if ! command -v "$gateway_name" >/dev/null 2>&1; then
      gateway_missing_commands+=("$gateway_name")
    fi
  done
}

gateway_brew_formula_for_command() {
  local gateway_name="$1"
  case "$gateway_name" in
    cargo|rustc) print -r -- rust ;;
    fastfetch) print -r -- fastfetch ;;
    ffmpeg) print -r -- ffmpeg ;;
    fzf) print -r -- fzf ;;
    gh) print -r -- gh ;;
    git) print -r -- git ;;
    go) print -r -- go ;;
    jq) print -r -- jq ;;
    node) print -r -- node ;;
    parallel) print -r -- parallel ;;
    rg) print -r -- ripgrep ;;
    whisper) print -r -- openai-whisper ;;
  esac
}

gateway_brew_cask_for_command() {
  local gateway_name="$1"
  case "$gateway_name" in
    codex) print -r -- codex ;;
  esac
}

gateway_install_missing_commands() {
  local -a gateway_formulae=()
  local -a gateway_casks=()
  typeset -A gateway_seen_formulae=()
  typeset -A gateway_seen_casks=()
  local gateway_name gateway_formula gateway_cask

  for gateway_name in "$@"; do
    gateway_formula="$(gateway_brew_formula_for_command "$gateway_name")"
    if [[ -n "$gateway_formula" && -z "${gateway_seen_formulae[$gateway_formula]-}" ]]; then
      gateway_formulae+=("$gateway_formula")
      gateway_seen_formulae[$gateway_formula]=1
    fi
    gateway_cask="$(gateway_brew_cask_for_command "$gateway_name")"
    if [[ -n "$gateway_cask" && -z "${gateway_seen_casks[$gateway_cask]-}" ]]; then
      gateway_casks+=("$gateway_cask")
      gateway_seen_casks[$gateway_cask]=1
    fi
  done

  if (( ${#gateway_formulae[@]} == 0 && ${#gateway_casks[@]} == 0 )); then
    return 0
  fi
  if ! command -v brew >/dev/null 2>&1; then
    print -u2 "setup cannot install missing commands because brew is missing from PATH."
    exit 69
  fi
  if (( ${#gateway_formulae[@]} )); then
    print -- "installing missing Homebrew formulae: ${gateway_formulae[*]}"
    brew install "${gateway_formulae[@]}"
  fi
  if (( ${#gateway_casks[@]} )); then
    print -- "installing missing Homebrew casks: ${gateway_casks[*]}"
    brew install --cask "${gateway_casks[@]}"
  fi
}

gateway_collect_missing_commands
gateway_install_missing_commands "${gateway_missing_commands[@]}"
gateway_collect_missing_commands

if (( ${#gateway_missing_commands[@]} )); then
  print -u2 "setup cannot register ai.gateway because required commands are missing from PATH."
  print -u2 "Install these commands or fix PATH before running setup:"
  for name in "${gateway_missing_commands[@]}"; do
    print -u2 "  - $name"
  done
  exit 69
fi

gateway_label="ai.gateway"
gateway_domain="gui/$(id -u)"
gateway_launch="$gateway_root/launch"
gateway_plist_template="$gateway_root/$gateway_label.plist"
gateway_plist_dest="$HOME/Library/LaunchAgents/$gateway_label.plist"
gateway_plist_tmp=
trap '[[ -z "${gateway_plist_tmp:-}" ]] || rm -f "$gateway_plist_tmp"' EXIT

if [[ ! -x "$gateway_launch" ]]; then
  print -u2 "LaunchAgent launcher is missing or not executable: $gateway_launch"
  exit 66
fi

if [[ ! -f "$gateway_plist_template" ]]; then
  print -u2 "LaunchAgent plist template is missing: $gateway_plist_template"
  exit 66
fi

cd "$gateway_root"
cargo build --release

gateway_xml_escape() {
  jq -nr --arg value "$1" '$value | @html'
}

gateway_launch_xml="$(gateway_xml_escape "$gateway_launch")"
gateway_plist_tmp="$gateway_plist_dest.$$"

mkdir -p "${gateway_plist_dest:h}"
while IFS= read -r line || [[ -n "$line" ]]; do
  line="${line//__GATEWAY_LAUNCH__/$gateway_launch_xml}"
  print -r -- "$line"
done < "$gateway_plist_template" > "$gateway_plist_tmp"
mv -f "$gateway_plist_tmp" "$gateway_plist_dest"
gateway_plist_tmp=

launchctl bootout "$gateway_domain/$gateway_label" 2>/dev/null || true
sleep 1
launchctl bootstrap "$gateway_domain" "$gateway_plist_dest"

print -- "registered and started $gateway_label from $gateway_plist_dest"
