#!/bin/zsh
set -euo pipefail

gateway_root="${0:A:h}"
gateway_bin="$gateway_root/target/release/gateway"
: "${HOME:?HOME is required}"

gateway_export_xdg_default() {
  local gateway_var_name="$1"
  local gateway_default_path="$2"
  local gateway_value="${(P)gateway_var_name:-}"

  if [[ -z "${gateway_value//[[:space:]]/}" ]]; then
    typeset -gx "$gateway_var_name=$gateway_default_path"
  else
    typeset -gx "$gateway_var_name=$gateway_value"
  fi
}

gateway_export_xdg_default XDG_CONFIG_HOME "$HOME/.config"
gateway_export_xdg_default XDG_CACHE_HOME "$HOME/.cache"
gateway_export_xdg_default XDG_DATA_HOME "$HOME/.local/share"
gateway_export_xdg_default XDG_STATE_HOME "$HOME/.local/state"

gateway_log_file="$XDG_STATE_HOME/gateway/logs/gateway.log"
if [[ ! -x "$gateway_bin" ]]; then
  print -u2 "gateway binary is missing or not executable: $gateway_bin"
  print -u2 "run: cd ${(q)gateway_root} && cargo build --release"
  exit 127
fi

mkdir -p "${gateway_log_file:h}"
exec >>"$gateway_log_file" 2>&1
print -- "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] starting gateway"
exec "$gateway_bin" bot
