#!/bin/zsh
set -euo pipefail

gateway_root="${0:A:h}"
gateway_bin="$gateway_root/target/release/gateway"
: "${HOME:?HOME is required}"

gateway_xdg_state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
[[ -n "${gateway_xdg_state_home//[[:space:]]/}" ]] || gateway_xdg_state_home="$HOME/.local/state"
gateway_log_file="$gateway_xdg_state_home/gateway/logs/gateway.log"
if [[ ! -x "$gateway_bin" ]]; then
  print -u2 "gateway binary is missing or not executable: $gateway_bin"
  print -u2 "run: cd ${(q)gateway_root} && cargo build --release"
  exit 127
fi

cd "$gateway_root"
mkdir -p "${gateway_log_file:h}"
exec >>"$gateway_log_file"
gateway_version="$("$gateway_bin" version 2>/dev/null || true)"
gateway_version="${gateway_version#gateway }"
[[ -n "${gateway_version//[[:space:]]/}" ]] || gateway_version="unknown"

gateway_log_icon() {
  local gateway_level="$1"
  case "$gateway_level" in
    INFO) print -r -- "ℹ️" ;;
    WARN) print -r -- "⚠️" ;;
    ERROR) print -r -- "❌" ;;
    *) print -r -- "🧾" ;;
  esac
}

gateway_log_line() {
  local gateway_level="$1"
  shift
  local gateway_line="$*"
  local gateway_icon
  gateway_icon="$(gateway_log_icon "$gateway_level")"
  if [[ "$gateway_line" == "ℹ️ "????-??-??" "??:??:??" v="* ]] \
    || [[ "$gateway_line" == "⚠️ "????-??-??" "??:??:??" v="* ]] \
    || [[ "$gateway_line" == "❌ "????-??-??" "??:??:??" v="* ]] \
    || [[ "$gateway_line" == "🧾 "????-??-??" "??:??:??" v="* ]]; then
    print -r -- "$gateway_line"
  else
    print -r -- "$gateway_icon $(date -u '+%Y-%m-%d %H:%M:%S') v=$gateway_version $gateway_line"
  fi
}

gateway_prefix_stream() {
  local gateway_level="$1"
  local gateway_line
  while IFS= read -r gateway_line || [[ -n "$gateway_line" ]]; do
    gateway_log_line "$gateway_level" "$gateway_line"
  done
}

gateway_log_line INFO "starting gateway"
gateway_exit_code=0
"$gateway_bin" bot \
  > >(gateway_prefix_stream INFO) \
  2> >(gateway_prefix_stream ERROR) || gateway_exit_code=$?
exit "$gateway_exit_code"
